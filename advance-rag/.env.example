# Database (PostgreSQL — shared with Node.js backend)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=knowledge_base
DB_USER=postgres
DB_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch
ES_HOST=http://localhost:9200
ES_PASSWORD=

# MinIO
MINIO_HOST=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# System Tenant ID (fixed UUID, must match across Node.js and Python)
SYSTEM_TENANT_ID=00000000-0000-0000-0000-000000000001

# Default Models (used to initialize system tenant on first startup)
DEFAULT_EMBEDDING_MODEL=
DEFAULT_CHAT_MODEL=
DEFAULT_RERANK_MODEL=
DEFAULT_ASR_MODEL=
DEFAULT_IMAGE2TEXT_MODEL=
DEFAULT_TTS_MODEL=

# FastAPI
API_HOST=0.0.0.0
API_PORT=9380
