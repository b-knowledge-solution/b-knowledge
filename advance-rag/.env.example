# Database (PostgreSQL — shared with Node.js backend)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=knowledge_base
DB_USER=postgres
DB_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Redis database number (must match BE REDIS_DB setting)
REDIS_DB=0

# Vector DB (OpenSearch)
DOC_ENGINE=opensearch
VECTORDB_HOST=http://localhost:9201
VECTORDB_PASSWORD=OpenSearch@123

# S3-Compatible Storage (RustFS / MinIO / etc.)
S3_HOST=localhost:9000
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
# Single-bucket mode (must match be/.env S3_BUCKET)
# Also configurable via conf/service_conf.yaml s3.bucket
S3_BUCKET=knowledge
# Optional: prefix path within the bucket (leave empty for no prefix)
S3_PREFIX_PATH=

# Worker concurrency (tune based on available CPU/memory)
MAX_CONCURRENT_TASKS=5
MAX_CONCURRENT_CHUNK_BUILDERS=1
MAX_CONCURRENT_MINIO=10
# OpenSearch connection pool size (should be >= MAX_CONCURRENT_TASKS)
OPENSEARCH_POOL_MAXSIZE=10

# System Tenant ID (fixed UUID, must match across Node.js and Python)
SYSTEM_TENANT_ID=00000000000000000000000000000001

# Default Models (used to initialize system tenant on first startup)
DEFAULT_EMBEDDING_MODEL=
DEFAULT_CHAT_MODEL=
DEFAULT_RERANK_MODEL=
DEFAULT_ASR_MODEL=
DEFAULT_IMAGE2TEXT_MODEL=
DEFAULT_TTS_MODEL=

# Local Embedding (Sentence Transformers)
# Set LOCAL_EMBEDDING_ENABLE=true to use self-hosted embedding instead of external APIs
LOCAL_EMBEDDING_ENABLE=false
# HuggingFace model ID (required when LOCAL_EMBEDDING_ENABLE=true). Example: BAAI/bge-m3
LOCAL_EMBEDDING_MODEL=
# Optional: local filesystem path to pre-downloaded model weights (offline/air-gapped mode)
LOCAL_EMBEDDING_PATH=

# Docling server URL for remote Docling deployment (optional)
# DOCLING_SERVER_URL=http://localhost:5001

# Logging
# Centralized log directory (all modules write here when set)
# Leave empty to use default <project>/logs
LOG_DIR=

# Memgraph (Code Knowledge Graph)
MEMGRAPH_BOLT_URL=bolt://localhost:7687
