{
  "swagger": "2.0",
  "info": {
    "title": "Item Catalog API",
    "version": "1.0.0",
    "description": "A sample Swagger 2.0 API for managing items."
  },
  "host": "api.example.com",
  "basePath": "/v1",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "tags": [
    {
      "name": "items",
      "description": "Item operations"
    }
  ],
  "paths": {
    "/items": {
      "get": {
        "tags": ["items"],
        "summary": "List all items",
        "operationId": "listItems",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "type": "string",
            "required": false,
            "description": "Filter by category"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Item"
              }
            }
          }
        }
      },
      "post": {
        "tags": ["items"],
        "summary": "Create a new item",
        "operationId": "createItem",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CreateItemRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Item created",
            "schema": {
              "$ref": "#/definitions/Item"
            }
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    }
  },
  "definitions": {
    "Item": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "price": {
          "type": "number",
          "format": "float"
        }
      },
      "required": ["id", "name"]
    },
    "CreateItemRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "price": {
          "type": "number",
          "format": "float"
        }
      },
      "required": ["name"]
    }
  }
}
