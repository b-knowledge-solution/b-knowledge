# ============================================================================
# Converter Worker — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment.
# These settings must match the backend Redis configuration (be/.env).

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_password_here
REDIS_DB=1

# Worker settings
POLL_INTERVAL=30

# Output directory for converted PDFs (relative or absolute)
# Leave empty to use default: converter/.data/converted
# CONVERTER_OUTPUT_DIR=
