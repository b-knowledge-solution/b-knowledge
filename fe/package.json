    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "js-tiktoken": "^1.0.21",
    "jszip": "^3.10.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.560.0",
    "mammoth": "^1.11.0",
    "mermaid": "^11.13.0",
    "nprogress": "^0.2.0",
    "papaparse": "^5.5.3",
