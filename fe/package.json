{
  "name": "knowledge-base-frontend",
  "version": "1.0.0",
  "description": "Frontend for RAGFlow AI Chat and AI Search proxy",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "predev": "node scripts/generate-permission-keys.mjs",
    "permissions:generate-keys": "node scripts/generate-permission-keys.mjs",
    "prebuild": "rimraf dist && node scripts/generate-permission-keys.mjs",
    "pretest": "node scripts/generate-permission-keys.mjs",
    "build": "tsc -b && vite build",
    "build:prod": "tsc -b && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "npm run test:run",
    "test:run": "npm run test:run:unit && npm run test:run:ui",
    "test:run:unit": "vitest run -c vitest.unit.config.ts",
    "test:run:ui": "vitest run -c vitest.ui.config.ts",
    "test:coverage": "vitest run -c vitest.unit.config.ts --coverage && vitest run -c vitest.ui.config.ts --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --project=chromium --grep @smoke",
    "test:e2e:setup": "playwright install chromium"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@casl/react": "^5.0.1",
    "@headlessui/react": "^2.2.9",
    "@js-preview/excel": "^1.7.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.12",
