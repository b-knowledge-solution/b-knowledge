# =============================================================================
# RAG Evaluation System - Environment Configuration Template
# =============================================================================
# 
# IMPORTANT: 
# - DO NOT commit .env (contains secrets)
# - Copy this file to .env and fill in real values
# - All variables below are REQUIRED
#
# How to obtain values:
# - BKNOWLEDGE_API_URL: Your B-Knowledge instance URL (e.g., http://localhost:3001)
# - BKNOWLEDGE_CHAT_TOKEN: Generate in B-Knowledge UI > Settings > Embed Tokens > Chat App
# - BKNOWLEDGE_SEARCH_TOKEN: Generate in B-Knowledge UI > Settings > Embed Tokens > Search App
# - LLM_JUDGE_API_KEY: OpenAI API key or other LLM provider
# - LANGFUSE_*: Optional, for observability (https://langfuse.com)
#
# =============================================================================

# =============================================================================
# REQUIRED: B-Knowledge API Configuration
# =============================================================================

# B-Knowledge API endpoint
# Examples:
#   - Local (host): http://localhost:3001
#   - Docker network: http://b-knowledge:3001
#   - From Docker container: http://host.docker.internal:3001
BKNOWLEDGE_API_URL=http://host.docker.internal:3001

# Chat App Embed Token
# Generate in B-Knowledge UI: Settings > Embed Tokens > + New Token > Chat App
BKNOWLEDGE_CHAT_TOKEN=

# Search App Embed Token
# Generate in B-Knowledge UI: Settings > Embed Tokens > + New Token > Search App
BKNOWLEDGE_SEARCH_TOKEN=

# =============================================================================
# REQUIRED: LLM Judge Configuration (for metrics evaluation)
# =============================================================================

# LLM Judge API Key
# Used for: Faithfulness, Answer Relevancy, Answer Correctness metrics
# Supports: OpenAI (gpt-4/gpt-3.5), Anthropic (claude-3), etc.
# Get OpenAI key: https://platform.openai.com/api-keys
LLM_JUDGE_API_KEY=sk-

# Optional: Specify LLM model for judge (default: gpt-3.5-turbo)
# Examples: gpt-4, gpt-3.5-turbo, claude-3-opus, claude-3-sonnet
LLM_JUDGE_MODEL=gpt-3.5-turbo

# Optional: Specify LLM provider (default: openai)
# Options: openai, anthropic
LLM_JUDGE_PROVIDER=openai

# =============================================================================
# OPTIONAL: Langfuse Integration (for observability)
# =============================================================================

# Langfuse is optional - for tracing and score annotation
# Sign up for free: https://cloud.langfuse.com
# Env format: https://{region}.langfuse.com (or https://cloud.langfuse.com for hosted)

# Langfuse host
# Default (hosted): https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com

# Langfuse Public Key
# Find in Langfuse Dashboard > Settings > API Keys
LANGFUSE_PUBLIC_KEY=

# Langfuse Secret Key
# Find in Langfuse Dashboard > Settings > API Keys
LANGFUSE_SECRET_KEY=

# =============================================================================
# OPTIONAL: Evaluation Settings
# =============================================================================

# Number of parallel requests to B-Knowledge (rate limiting)
# Recommended: 1-3 (to avoid overwhelming the API)
EVAL_CONCURRENT_REQUESTS=1

# Timeout for API calls (in seconds)
EVAL_API_TIMEOUT=30

# Enable debug logging
# Options: "true", "false"
DEBUG=false

# =============================================================================
# Advanced: Docker Networking
# =============================================================================

# If B-Knowledge is running in Docker on same network:
# Change BKNOWLEDGE_API_URL to:
#   http://b-knowledge:3001
# And uncomment below to use same Docker network
# Note: docker-compose.yml must define the network

# DOCKER_NETWORK=eval
# DOCKER_NETWORK_MODE=bridge
