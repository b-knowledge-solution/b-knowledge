# Knowledge Base Docker Environment Configuration
# Copy this file to .env and modify as needed

# ==========================================================================
# General Settings
# ==========================================================================
NODE_ENV=production
LOG_LEVEL=info
# Ignore self-signed certificates (WARNING: INSECURE - Development only)
IGNORE_SELF_SIGNED_CERTS=false

# ==========================================================================
# Image Settings
# ==========================================================================
# Names and tags for the three app images built by scripts/build-images.sh
BACKEND_IMAGE=kb-backend
BACKEND_VERSION=latest
RAG_IMAGE=kb-worker
RAG_VERSION=latest
CONVERTER_IMAGE=kb-converter
CONVERTER_VERSION=latest
FRONTEND_IMAGE=kb-frontend
FRONTEND_VERSION=latest
DEMO_IMAGE=kb-demo
DEMO_VERSION=latest
# Port the frontend container is exposed on the host
FRONTEND_PORT=5173

# ==========================================================================
# PostgreSQL Configuration
# ==========================================================================
DB_HOST=postgres
DB_NAME=knowledge_base
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_PORT=5432

# ==========================================================================
# Valkey (Redis-Compatible) Configuration
# ==========================================================================
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================================================
# Session Configuration
# ==========================================================================
SESSION_SECRET=change_this_to_a_long_random_string_in_production
SESSION_TTL_DAYS=7

# ==========================================================================
# Shared Storage Domain
# ==========================================================================
# For cross-subdomain cookie sharing, use parent domain with leading dot
# Example: .example.com for app.example.com and api.example.com
SHARED_STORAGE_DOMAIN=.localhost

# ==========================================================================
# Frontend URL
# ==========================================================================
FRONTEND_URL=http://localhost:5173

# ==========================================================================
# Langfuse Configuration (Optional)
# ==========================================================================
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ==========================================================================
# Azure AD (Entra ID) Configuration
# ==========================================================================
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URI=http://localhost:3001/api/auth/callback
# Optional proxy URL for Azure AD requests
NODE_USE_ENV_PROXY=1
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
# ==========================================================================
# Admin Configuration
# ==========================================================================
ADMIN_API_KEY=change_me_in_production
ENABLE_LOCAL_LOGIN=false
KB_ROOT_USER=admin@localhost
KB_ROOT_PASSWORD=admin

# Force language detection to a fixed code (e.g. 'eng'). Leave empty for auto-detection.
# FORCE_LANGUAGE=eng
# Language detection method: 'builtin' (default, fast) or 'llm' (uses default chat LLM, more accurate).
# LANGUAGE_DETECT_METHOD=builtin

# ==========================================================================
# OpenSearch / VectorDB Configuration
# ==========================================================================
VECTORDB_PASSWORD=OpenSearch@123
OPENSEARCH_DISABLE_SECURITY=true
# Full URL used by backend and advance-rag to connect to OpenSearch
VECTORDB_HOST=http://opensearch:9201

# ==========================================================================
# Memgraph Configuration (Code Knowledge Graph)
# ==========================================================================
MEMGRAPH_BOLT_PORT=7687
MEMGRAPH_WEB_PORT=7444

# ==========================================================================
# S3-Compatible Storage Configuration (RustFS / MinIO / etc.)
# ==========================================================================
S3_ENDPOINT=rustfs
S3_PORT=9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_USE_SSL=false
# S3 bucket name — must match advance-rag S3_BUCKET
S3_BUCKET=knowledge
# Optional: prefix path within the bucket (must match advance-rag S3_PREFIX_PATH)
S3_PREFIX_PATH=
# Combined host:port used by backend and advance-rag workers (service name in Docker network)
S3_HOST=rustfs:9000

# ==========================================================================
# RAG Worker Scaling (task-executor + converter)
# ==========================================================================
# Per-instance concurrency limits (tune based on CPU/memory per container)
MAX_CONCURRENT_TASKS=5
MAX_CONCURRENT_CHUNK_BUILDERS=1
MAX_CONCURRENT_MINIO=10
MAX_CONCURRENT_CHATS=10
# Max retries before abandoning a task
TASK_MAX_RETRIES=3
# OpenSearch connection pool size per worker (should be >= MAX_CONCURRENT_TASKS)
OPENSEARCH_POOL_MAXSIZE=10
# Embedding batch size (16 for OpenAI, up to 96 for Cohere)
EMBEDDING_BATCH_SIZE=16
# Chunks per bulk insert request (lower = less memory, higher = fewer requests)
DOC_BULK_SIZE=4
# Seconds before a worker is considered dead (heartbeat timeout)
WORKER_HEARTBEAT_TIMEOUT=120
# Converter polling interval in seconds
CONVERTER_POLL_INTERVAL=30

# ==========================================================================
# Local Embedding (Sentence Transformers)
# ==========================================================================
LOCAL_EMBEDDING_ENABLE=false
LOCAL_EMBEDDING_MODEL=
LOCAL_EMBEDDING_PATH=

# ==========================================================================
# Advance-RAG Worker Runtime
# ==========================================================================
# Database driver for Peewee ORM (must be postgres)
DB_TYPE=postgres
# Vector/document engine (opensearch only for now)
DOC_ENGINE=opensearch
# Root path inside the container — used by common/file_utils.py
RAG_PROJECT_BASE=/app
PYTHONPATH=/app

# ==========================================================================
# Logging (shared across all workers)
# ==========================================================================
LOG_DIR=/app/logs
LOG_ROTATION=50 MB
LOG_RETENTION=30 days
LOG_COMPRESSION=zip

# ==========================================================================
# External Config Files (JSON)
# ==========================================================================
# These configs can be customized via Docker volume mount at /app/config/
# Or set custom paths via environment variables below.
#
# System Tools: Configure monitoring tools displayed in the UI
# SYSTEM_TOOLS_CONFIG_PATH=/app/config/system-tools.config.json
#
# RAGFlow: Configure AI Chat and Search iframe URLs and sources
# RAGFLOW_CONFIG_PATH=/app/config/ragflow.config.json
