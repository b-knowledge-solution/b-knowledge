# =============================================================================
# Nexus Repository Configuration — Offline Docker Builds
# =============================================================================
# Copy this file to docker/nexus.env and fill in your Nexus server details.
# Used by scripts/build-*-offline.sh to route all package downloads and base
# image pulls through your local Nexus Repository Manager.
#
# -----------------------------------------------------------------------------
# PREREQUISITES — push these images to your Nexus Docker registry first:
#
#   docker pull node:22-alpine
#   docker pull python:3.11-slim
#   docker pull debian:bookworm-slim
#   docker pull infiniflow/ragflow_deps:latest
#
#   docker tag node:22-alpine          <NEXUS_REGISTRY>/node:22-alpine
#   docker tag python:3.11-slim        <NEXUS_REGISTRY>/python:3.11-slim
#   docker tag debian:bookworm-slim    <NEXUS_REGISTRY>/debian:bookworm-slim
#   docker tag infiniflow/ragflow_deps:latest <NEXUS_REGISTRY>/infiniflow/ragflow_deps:latest
#
#   docker push <NEXUS_REGISTRY>/node:22-alpine
#   docker push <NEXUS_REGISTRY>/python:3.11-slim
#   docker push <NEXUS_REGISTRY>/debian:bookworm-slim
#   docker push <NEXUS_REGISTRY>/infiniflow/ragflow_deps:latest
#
# Nexus repository types needed:
#   - docker-hosted or docker-group  (port 8083 by default)
#   - npm-proxy or npm-group         → proxies https://registry.npmjs.org
#   - pypi-proxy                     → proxies https://pypi.org/simple/
#   - pypi-torch-cpu (raw/hosted)    → hosts https://download.pytorch.org/whl/cpu/
#   - apt-proxy                      → proxies http://deb.debian.org/debian
#                                      + http://security.debian.org/debian-security
# =============================================================================

# ---------------------------------------------------------------------------
# Docker Registry
# Format: host:port  (no http/https prefix — Docker handles the scheme)
# ---------------------------------------------------------------------------
NEXUS_REGISTRY=nexus.example.com:8083

# ---------------------------------------------------------------------------
# npm Proxy / Group Repository
# Used by: be/Dockerfile.offline (Node.js / npm install)
# Configure your Nexus npm-proxy to upstream: https://registry.npmjs.org
# ---------------------------------------------------------------------------
NEXUS_NPM_REGISTRY=http://nexus.example.com:8081/repository/npm-group/

# ---------------------------------------------------------------------------
# PyPI Proxy Repository  (pip --index-url)
# Used by: advance-rag/Dockerfile.offline, converter/Dockerfile.offline
# Configure your Nexus pypi-proxy to upstream: https://pypi.org
# The /simple/ suffix is required by pip's PEP 503 interface.
# ---------------------------------------------------------------------------
NEXUS_PIP_INDEX=http://nexus.example.com:8081/repository/pypi-proxy/simple/

# Trusted host for pip HTTP connections (derived automatically from NEXUS_PIP_INDEX
# if omitted, but set explicitly here to avoid runtime parsing issues)
NEXUS_PIP_INDEX_HOST=nexus.example.com

# ---------------------------------------------------------------------------
# PyTorch CPU Wheels Repository  (separate from general PyPI)
# Used by: advance-rag/Dockerfile.offline
# Must host the CPU-only torch wheel files from:
#   https://download.pytorch.org/whl/cpu/
# Typically a Nexus raw-hosted repo with those wheels uploaded, or a
# proxy group combining pypi-proxy + a torch-cpu raw proxy.
# ---------------------------------------------------------------------------
NEXUS_TORCH_INDEX=http://nexus.example.com:8081/repository/pypi-torch-cpu/simple/

# Trusted host for pip HTTP connections to torch index
NEXUS_TORCH_INDEX_HOST=nexus.example.com

# ---------------------------------------------------------------------------
# APT Proxy Repository  (Debian package mirror)
# Used by: advance-rag/Dockerfile.offline, converter/Dockerfile.offline
# Configure your Nexus apt-proxy to upstream Debian mirrors:
#   - http://deb.debian.org/debian          (main)
#   - http://security.debian.org/debian-security  (security updates)
# The proxy URL is used for bookworm, bookworm-security, and bookworm-updates.
# ---------------------------------------------------------------------------
NEXUS_APT_MIRROR=http://nexus.example.com:8081/repository/apt-proxy/

# ---------------------------------------------------------------------------
# RAGFlow Dependencies Image
# Pre-built image containing ML models, NLTK data, tika JAR, tiktoken files.
# Must be pushed to your local Docker registry before building.
# (See PREREQUISITES section at the top of this file.)
# ---------------------------------------------------------------------------
RAGFLOW_DEPS_IMAGE=nexus.example.com:8083/infiniflow/ragflow_deps:latest
